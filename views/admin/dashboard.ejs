<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>

<div class="container-fluid p-0">
    <div class="row g-0">
        <%- include('partials/sidebar') %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-0 bg-light min-vh-100">
            
            <%- include('partials/navbar') %>

            <div class="px-4 pt-4 pb-5">
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="stats-card p-3 border-start border-primary">
                            <div class="d-flex align-items-center">
                                <div class="icon-box bg-primary bg-opacity-10 me-3">
                                    <i class="bi bi-currency-dollar text-primary fs-3"></i>
                                </div>
                                <div>
                                    <p class="text-muted mb-1 small fw-bold text-uppercase">Doanh thu</p>
                                    <h4 class="mb-0 fw-bold text-dark">
                                        <%= stats.revenue.toLocaleString('vi-VN') %> đ
                                    </h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stats-card p-3 border-start border-success">
                            <div class="d-flex align-items-center">
                                <div class="icon-box bg-success bg-opacity-10 me-3">
                                    <i class="bi bi-cart-check text-success fs-3"></i>
                                </div>
                                <div>
                                    <p class="text-muted mb-1 small fw-bold text-uppercase">Đơn hàng</p>
                                    <h4 class="mb-0 fw-bold text-dark"><%= stats.orders %></h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stats-card p-3 border-start border-warning">
                            <div class="d-flex align-items-center">
                                <div class="icon-box bg-warning bg-opacity-10 me-3">
                                    <i class="bi bi-box-seam text-warning fs-3"></i>
                                </div>
                                <div>
                                    <p class="text-muted mb-1 small fw-bold text-uppercase">Sản phẩm</p>
                                    <h4 class="mb-0 fw-bold text-dark"><%= stats.products %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 shadow-sm rounded-3 min-vh-50 border">
                    <h5 class="fw-bold mb-3">Chào mừng trở lại, <%= user ? user.fullname : 'Admin' %>!</h5>
                    <p class="text-muted">Chọn một mục từ menu bên trái để bắt đầu quản lý.</p>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>