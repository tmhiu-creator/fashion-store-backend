<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>

<div class="container-fluid p-0">
    <div class="row g-0">
        <%- include('partials/sidebar') %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-0 bg-light min-vh-100">
            <%- include('partials/navbar') %>

            <div class="px-4 pt-4 pb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-header bg-white py-3 border-bottom">
                                <h5 class="mb-0 fw-bold">
                                    <i class="bi bi-box-seam me-2 text-primary"></i> 
                                    <%= editing ? 'Chỉnh Sửa Sản Phẩm' : 'Thêm Sản Phẩm Mới' %>
                                </h5>
                            </div>
                            <div class="card-body p-4">
                                <form action="/admin/<%= editing ? 'edit-product' : 'add-product' %>" method="POST" enctype="multipart/form-data">
                                    
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-uppercase text-muted">Tên sản phẩm</label>
                                        <input type="text" name="name" class="form-control bg-light border-0 py-3" required 
                                               value="<%= editing ? product.name : '' %>" placeholder="Ví dụ: Áo Thun Basic...">
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold small text-uppercase text-muted">Giá tiền (VNĐ)</label>
                                            <input type="number" name="price" class="form-control bg-light border-0 py-3" required 
                                                   value="<%= editing ? product.price : '' %>">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold small text-uppercase text-muted">Danh mục</label>
                                            <select name="category_id" class="form-select bg-light border-0 py-3">
                                                <option value="cat_nam" <%= (editing && product.category_id === 'cat_nam') ? 'selected' : '' %>>Thời trang Nam</option>
                                                <option value="cat_nu" <%= (editing && product.category_id === 'cat_nu') ? 'selected' : '' %>>Thời trang Nữ</option>
                                                <option value="cat_kid" <%= (editing && product.category_id === 'cat_kid') ? 'selected' : '' %>>Trẻ em</option>
                                                <option value="cat_watch" <%= (editing && product.category_id === 'cat_watch') ? 'selected' : '' %>>Đồng hồ</option>
                                                <option value="cat_bag" <%= (editing && product.category_id === 'cat_bag') ? 'selected' : '' %>>Túi xách</option>
                                                <option value="cat_glass" <%= (editing && product.category_id === 'cat_glass') ? 'selected' : '' %>>Kính Mắt</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3 border rounded p-3 bg-light">
                                        <label class="form-label fw-bold small text-uppercase text-muted mb-3">Hình ảnh sản phẩm</label>
                                        
                                        <div class="mb-3">
                                            <label class="form-label small text-muted">1. Tải ảnh từ máy tính (Ưu tiên):</label>
                                            <input type="file" name="imageFile" class="form-control" accept="image/*">
                                        </div>

                                        <div class="text-center text-muted small my-2">- HOẶC -</div>

                                        <div class="mb-2">
                                            <label class="form-label small text-muted">2. Dán Link ảnh (URL):</label>
                                            <input type="url" name="imageURL" class="form-control bg-white border" 
                                                   value="<%= editing ? product.image : '' %>" placeholder="https://...">
                                        </div>

                                        <% if (editing) { %>
                                            <div class="mt-3">
                                                <small class="text-muted d-block mb-1">Ảnh hiện tại:</small>
                                                <img src="<%= product.image %>" height="80" class="rounded border">
                                            </div>
                                        <% } %>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold small text-uppercase text-muted">Size (Cách nhau dấu phẩy)</label>
                                            <input type="text" name="sizes" class="form-control bg-light border-0 py-3" 
                                                   value="<%= editing ? product.sizes.join(', ') : '' %>" placeholder="S, M, L">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold small text-uppercase text-muted">Màu sắc (Tiếng Anh/Mã màu)</label>
                                            <input type="text" name="colors" class="form-control bg-light border-0 py-3" 
                                                   value="<%= editing ? product.colors.join(', ') : '' %>" placeholder="Black, White">
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold small text-uppercase text-muted">Mô tả sản phẩm</label>
                                        <textarea name="description" rows="5" class="form-control bg-light border-0"><%= editing ? product.description : '' %></textarea>
                                    </div>

                                    <% if (editing) { %>
                                        <input type="hidden" name="productId" value="<%= product._id %>">
                                    <% } %>

                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/admin/products" class="btn btn-light px-4 fw-bold">Hủy bỏ</a>
                                        <button type="submit" class="btn btn-primary px-5 fw-bold shadow">
                                            <i class="bi bi-check-lg me-2"></i> <%= editing ? 'Cập Nhật' : 'Lưu Sản Phẩm' %>
                                        </button>
                                    </div>

                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>