<div class="offcanvas-lg offcanvas-start bg-dark text-white sidebar-nav" tabindex="-1" id="adminSidebar">
    <div class="offcanvas-header border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold"> <i class="bi bi-bag-heart-fill text-primary"></i> H-Fashion Admin</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#adminSidebar"></button>
    </div>
    
    <div class="offcanvas-body p-0">
        <div class="d-flex flex-column h-100 py-3">
            <div class="px-4 mb-4 text-center">
                <div class="bg-primary bg-opacity-25 rounded-circle mx-auto d-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-fill fs-2 text-primary"></i>
                </div>
                <h6 class="fw-bold mb-0"><%= user.fullname || 'Admin' %></h6>
                <small class="text-white-50">Administrator</small>
            </div>

            <nav class="nav flex-column px-2 gap-1">
                <a class="nav-link text-white-50 rounded px-3 py-2 d-flex align-items-center hover-light" href="/admin/dashboard">
                    <i class="bi bi-speedometer2 me-3 fs-5"></i> Dashboard
                </a>
                
                <a class="nav-link text-white-50 rounded px-3 py-2 d-flex align-items-center hover-light" href="/admin/orders">
                    <i class="bi bi-cart3 me-3 fs-5"></i> Quản lý Đơn hàng
                </a>

                <a class="nav-link text-white-50 rounded px-3 py-2 d-flex align-items-center hover-light" href="/admin/products">
                    <i class="bi bi-box-seam me-3 fs-5"></i> Quản lý Sản phẩm
                </a>

                <a class="nav-link text-white-50 rounded px-3 py-2 d-flex align-items-center hover-light" href="/admin/users">
                    <i class="bi bi-people me-3 fs-5"></i> Quản lý Khách hàng
                </a>
            </nav>
            
            <div class="mt-auto px-4 pt-4 border-top border-secondary">
                <a href="/" class="btn btn-outline-light w-100 rounded-pill"><i class="bi bi-box-arrow-left me-2"></i> Về Website</a>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS chung cho Sidebar */
    .sidebar-nav {
        width: 260px; /* Chiều rộng cố định */
        transition: all 0.3s;
    }
    .nav-link.active, .nav-link:hover {
        background-color: rgba(255,255,255,0.1);
        color: #fff !important;
    }

    /* --- GIAO DIỆN LAPTOP/DESKTOP (Màn hình > 992px) --- */
    @media (min-width: 992px) {
        /* 1. Sidebar luôn hiện và cố định bên trái */
        #adminSidebar {
            position: fixed !important;
            top: 0; bottom: 0; left: 0;
            z-index: 1040;
            transform: none !important;
            visibility: visible !important;
        }

        /* 2. Đẩy phần nội dung chính (main) sang phải để không bị Sidebar che mất */
        /* Ghi đè lên các class col-lg-10 cũ nếu có */
        main {
            margin-left: 260px !important; 
            width: calc(100% - 260px) !important;
            flex: 0 0 auto !important;
            max-width: none !important;
        }
    }

    /* --- GIAO DIỆN MOBILE (Màn hình < 992px) --- */
    @media (max-width: 991.98px) {
        /* Trả lại trạng thái bình thường cho main */
        main {
            margin-left: 0 !important;
            width: 100% !important;
        }
    }
</style>