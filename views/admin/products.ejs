<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>

<div class="container-fluid p-0">
    <div class="row g-0">
        <%- include('partials/sidebar') %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-0 bg-light min-vh-100">
            <%- include('partials/navbar') %>

            <div class="px-4 pt-4 pb-5">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <h4 class="fw-bold mb-0 text-dark">Danh Sách Sản Phẩm</h4>
                    <a href="/admin/add-product" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                        <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm
                    </a>
                </div>

                <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                    <div class="card-body p-0">
                        
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 text-nowrap">
                                <thead class="bg-light text-secondary text-uppercase small fw-bold">
                                    <tr>
                                        <th class="py-3 ps-4">Hình ảnh</th>
                                        <th class="py-3">Tên sản phẩm</th>
                                        <th class="py-3">Danh mục</th>
                                        <th class="py-3">Giá tiền</th>
                                        <th class="py-3 text-center">Đã bán</th>
                                        <th class="py-3 text-end pe-4">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% products.forEach(product => { %>
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <img src="<%= product.image %>" class="rounded border shadow-sm object-fit-cover" width="60" height="60" alt="Img" onerror="this.src='https://placehold.co/60'">
                                            </td>
                                            <td>
                                                <h6 class="mb-0 fw-bold text-dark"><%= product.name %></h6>
                                                <small class="text-muted">ID: <%= product._id.toString().slice(-6).toUpperCase() %></small>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border"><%= product.category_id || 'Chưa phân loại' %></span>
                                            </td>
                                            <td class="fw-bold text-primary">
                                                <%= product.price ? product.price.toLocaleString('vi-VN') : 0 %> đ
                                            </td>
                                            <td class="text-center text-muted">
                                                <%= product.sold || 0 %>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a href="/admin/edit-product/<%= product._id %>" class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>

                                                <form action="/admin/delete-product" method="POST" style="display: inline-block;">
                                                    <input type="hidden" name="productId" value="<%= product._id %>">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')" title="Xóa">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>