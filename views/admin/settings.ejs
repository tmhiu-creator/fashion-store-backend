<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>

<div class="container-fluid p-0">
    <div class="row g-0">
        <%- include('partials/sidebar') %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-0 bg-light min-vh-100">
            <%- include('partials/navbar') %>

            <div class="px-4 pt-4 pb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0 text-dark">Cài Đặt Hệ Thống</h4>
                </div>

                <form action="/admin/settings" method="POST">
                    <div class="row g-4">
                        
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-header bg-white py-3 border-bottom">
                                    <h6 class="mb-0 fw-bold text-primary"><i class="bi bi-shop me-2"></i>Thông tin cửa hàng</h6>
                                </div>
                                <div class="card-body p-4">
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Tên cửa hàng</label>
                                        <input type="text" name="storeName" class="form-control bg-light border-0 py-3" value="<%= settings.storeName %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Hotline</label>
                                        <input type="text" name="storePhone" class="form-control bg-light border-0 py-3" value="<%= settings.storePhone %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Email liên hệ</label>
                                        <input type="email" name="storeEmail" class="form-control bg-light border-0 py-3" value="<%= settings.storeEmail %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Địa chỉ</label>
                                        <textarea name="storeAddress" rows="3" class="form-control bg-light border-0"><%= settings.storeAddress %></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-4 mb-4">
                                <div class="card-header bg-white py-3 border-bottom">
                                    <h6 class="mb-0 fw-bold text-success"><i class="bi bi-truck me-2"></i>Cấu hình vận chuyển</h6>
                                </div>
                                <div class="card-body p-4">
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Phí ship mặc định (VNĐ)</label>
                                        <input type="number" name="shippingFee" class="form-control bg-light border-0 py-3" value="<%= settings.shippingFee %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Đơn hàng Freeship từ (VNĐ)</label>
                                        <input type="number" name="freeShippingThreshold" class="form-control bg-light border-0 py-3" value="<%= settings.freeShippingThreshold %>">
                                        <div class="form-text">Ví dụ: Nhập 500000 (Đơn trên 500k sẽ được miễn phí ship).</div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-header bg-white py-3 border-bottom">
                                    <h6 class="mb-0 fw-bold text-info"><i class="bi bi-share me-2"></i>Kết nối mạng xã hội</h6>
                                </div>
                                <div class="card-body p-4">
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Facebook Fanpage (URL)</label>
                                        <input type="url" name="facebook" class="form-control bg-light border-0 py-3" placeholder="https://facebook.com/..." value="<%= settings.facebook %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Zalo OA (Link/SĐT)</label>
                                        <input type="text" name="zalo" class="form-control bg-light border-0 py-3" value="<%= settings.zalo %>">
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="fixed-bottom bg-white border-top p-3 shadow-lg" style="margin-left: 16.66667%;"> 
                        <div class="container-fluid d-flex justify-content-end px-4">
                            <button type="reset" class="btn btn-light me-3 px-4 fw-bold">Hủy thay đổi</button>
                            <button type="submit" class="btn btn-primary px-5 fw-bold shadow">
                                <i class="bi bi-save me-2"></i> Lưu Cấu Hình
                            </button>
                        </div>
                    </div>
                </form>
                
                <div style="height: 100px;"></div> 
            </div>
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>