<%- include('partials/header.ejs') %>

<link rel="stylesheet" href="/css/home.css">

<% 
    const keyword = (typeof currentKeyword !== 'undefined') ? currentKeyword : ''; 
    const category = (typeof currentCategory !== 'undefined') ? currentCategory : ''; 
    const bannerList = (typeof banners !== 'undefined') ? banners : [];
%>

<div class="home-wrapper min-vh-100">

  <% if (!keyword && !category) { %>
      <div class="container-fluid p-0">
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
          <div class="carousel-indicators">
            <% if (bannerList.length > 0) { %>
                <% bannerList.forEach((item, index) => { %>
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="<%= index %>" class="<%= index === 0 ? 'active' : '' %>"></button>
                <% }); %>
            <% } %>
          </div>
          <div class="carousel-inner">
            <% if (bannerList.length > 0) { %>
                <% bannerList.forEach((item, index) => { %>
                    <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                        <div class="carousel-overlay"></div>
                        <img src="<%= item.image %>" class="d-block w-100 hero-img" alt="<%= item.title %>" style="height: 85vh; object-fit: cover;" onerror="this.src='https://placehold.co/1920x1080/333/FFF?text=Banner+Loi'">
                        <div class="carousel-content container h-100 d-flex align-items-center text-start">
                            <div class="text-white col-lg-8 ps-lg-5" style="z-index: 10;">
                                <span class="text-uppercase ls-3 small fw-bold mb-3 d-block text-warning"><%= item.title %></span>
                                <h1 class="display-1 fw-bold mb-4 font-heading"><%= item.subtitle %></h1>
                                <a href="#shop-section" class="btn btn-outline-light rounded-0 px-5 py-3 text-uppercase fw-bold ls-1 hover-fill">Mua Ngay</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
          </div>
        </div>
      </div>

      <section class="container my-5 py-5">
        <div class="row g-0 align-items-center shadow-lg rounded-4 overflow-hidden countdown-wrapper bg-white">
          <div class="col-lg-5 p-5 position-relative z-1">
            <div class="d-flex align-items-center mb-3">
              <div class="line me-3 bg-dark" style="width: 40px; height: 2px;"></div>
              <span class="text-uppercase fw-bold ls-2 text-muted small">Sự Kiện Đặc Biệt</span>
            </div>
            <h2 class="display-4 fw-bold mb-4 font-heading text-dark">Siêu Sale <br><span class="text-gradient">Giữa Mùa</span></h2>
            <div class="timer-grid d-flex gap-3 mb-5" id="countdown-timer">
              <div class="timer-item"><span class="time-val" id="days">00</span><span class="time-label">Ngày</span></div>
              <div class="timer-item"><span class="time-val" id="hours">00</span><span class="time-label">Giờ</span></div>
              <div class="timer-item"><span class="time-val" id="minutes">00</span><span class="time-label">Phút</span></div>
              <div class="timer-item bg-dark text-white"><span class="time-val" id="seconds">00</span><span class="time-label text-white-50">Giây</span></div>
            </div>
            <button class="btn btn-dark rounded-pill px-5 py-3 fw-bold text-uppercase shadow hover-top" onclick="window.location.href='#shop-section'">Xem Chi Tiết</button>
          </div>
          <div class="col-lg-7 h-100 position-relative countdown-visual">
            <div class="overlay-gradient-h"></div>
            <img src="https://i.pinimg.com/1200x/ed/ce/7e/edce7ee759bff1094544bfc97415083e.jpg" class="img-fluid w-100 h-100 object-fit-cover" alt="Sale Event">
            <div class="floating-badge"><span class="d-block fs-3 fw-bold">50%</span><span class="text-uppercase small ls-1">OFF</span></div>
          </div>
        </div>
      </section>
  <% } else { %>
      <div style="height: 20px;"></div>
  <% } %>

  <div class="container mb-5 pb-5" id="shop-section">
    <div class="d-flex justify-content-between align-items-end mb-5 pt-5">
      <div>
        <h6 class="text-uppercase text-muted ls-2 mb-2 small fw-bold">Bộ Sưu Tập</h6>
        
        <% if (keyword) { %>
            <h2 class="display-6 fw-bold font-heading text-dark m-0">Tìm kiếm: "<span class="text-primary"><%= keyword %></span>"</h2>
        <% } else if (category) { %>
            <h2 class="display-6 fw-bold font-heading text-dark m-0">Danh mục: <span class="text-primary"><%= category %></span></h2>
        <% } else { %>
            <h2 class="display-6 fw-bold font-heading text-dark m-0">Sản Phẩm Mới Nhất</h2>
        <% } %>
      </div>
      
      <% if (keyword || category) { %>
          <a href="/" class="btn btn-outline-danger rounded-pill px-4">Xóa bộ lọc</a>
      <% } %>
    </div>

    <% if (!products || products.length === 0) { %>
        <div class="text-center py-5 my-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-search fs-1 text-muted"></i>
            <h4 class="mt-3 text-muted">Không tìm thấy sản phẩm nào!</h4>
            <a href="/" class="btn btn-dark mt-3 rounded-pill px-4">Xem tất cả sản phẩm</a>
        </div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 gy-5 gx-4">
        <% products.forEach(function(fashion) { %>
          <div class="col">
            <div class="product-item">
              
              <div class="product-thumb">
                  <a href="/product/<%= fashion._id %>" class="d-block w-100 h-100">
                      <img src="<%= fashion.image %>" class="product-img" alt="<%= fashion.name %>" onerror="this.src='https://placehold.co/400x400?text=No+Image'">
                  </a>
                  <span class="badge bg-white text-dark position-absolute top-0 start-0 m-3 px-3 py-2 text-uppercase fw-bold small shadow-sm">New</span>
                  
                  <div class="product-actions">
                    <button class="action-btn" onclick="window.location.href='/product/<%= fashion._id %>'"><i class="bi bi-eye"></i></button>
                    
                    <button class="action-btn" type="button" 
                        data-id="<%= fashion._id %>"
                        data-name="<%= fashion.name %>"
                        data-price="<%= fashion.price || 0 %>"
                        data-image="<%= fashion.image %>"
                        onclick="addToCartV2(this)">
                        <i class="bi bi-bag-plus"></i>
                    </button>
                  </div>
              </div>

              <a href="/product/<%= fashion._id %>" class="text-decoration-none">
                  <div class="product-details pt-3 text-center">
                      <div class="text-warning small mb-1"><i class="bi bi-star-fill"></i> <%= fashion.rating || 4.8 %></div>
                      <h5 class="product-name text-dark text-truncate px-2"><%= fashion.name %></h5>
                      <div class="product-price">
                          <span class="fw-bold text-dark"><%= fashion.price ? fashion.price.toLocaleString('vi-VN') : 0 %> đ</span>
                      </div>
                  </div>
              </a>

            </div>
          </div>
        <% }); %>
        </div>

        <nav class="mt-5 pt-4 d-flex justify-content-center">
            <ul class="pagination pagination-minimal gap-2 align-items-center" style="list-style: none; padding: 0;">
                <li class="page-item <%= !hasPreviousPage ? 'disabled' : '' %>">
                    <a class="page-link border-0 bg-transparent text-dark fs-5" 
                       href="/?page=<%= previousPage %><%= keyword ? '&keyword=' + keyword : '' %><%= category ? '&category=' + category : '' %>">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                </li>

                <% for(let i = 1; i <= lastPage; i++) { %>
                    <li class="page-item">
                        <a class="page-link rounded-circle border-0 fw-bold <%= currentPage === i ? 'active-dot' : 'text-muted' %>" 
                           style="width: 40px; height: 40px; display:flex; align-items:center; justify-content:center; text-decoration:none;"
                           href="/?page=<%= i %><%= keyword ? '&keyword=' + keyword : '' %><%= category ? '&category=' + category : '' %>">
                            <%= i %>
                        </a>
                    </li>
                <% } %>

                <li class="page-item <%= !hasNextPage ? 'disabled' : '' %>">
                    <a class="page-link border-0 bg-transparent text-dark fs-5" 
                       href="/?page=<%= nextPage %><%= keyword ? '&keyword=' + keyword : '' %><%= category ? '&category=' + category : '' %>">
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    <% } %>
  </div>

  <div class="floating-contact-group" id="contactGroup">
    <div class="contact-sub-buttons">
      <a href="tel:0829787803" class="sub-btn btn-phone"><i class="bi bi-telephone-fill"></i></a>
      <a href="#" class="sub-btn btn-zalo"><span class="zalo-text">Zalo</span></a>
      <a href="#" class="sub-btn btn-x"><i class="bi bi-twitter-x"></i></a>
    </div>
    <div class="contact-main-btn" onclick="toggleContact()">
      <div class="pulse-ring"></div>
      <i class="bi bi-headset icon-fix"></i>
    </div>
  </div>

</div>

<script src="/js/home.js"></script>
<%- include('partials/footer.ejs') %>