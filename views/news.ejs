<%- include('partials/header') %>

<div class="container py-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold font-heading">Tin Tức & Xu Hướng</h2>
        <p class="text-muted">Cập nhật những thông tin thời trang mới nhất</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <% newsList.forEach(item => { %>
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-card">
                    <a href="/news/<%= item._id %>">
                        <img src="<%= item.image %>" class="card-img-top object-fit-cover" height="250" alt="<%= item.title %>">
                    </a>
                    <div class="card-body p-4">
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">
                            <%= new Date(item.createdAt).toLocaleDateString('vi-VN') %>
                        </small>
                        <h5 class="card-title fw-bold mt-2 mb-3">
                            <a href="/news/<%= item._id %>" class="text-decoration-none text-dark stretched-link">
                                <%= item.title %>
                            </a>
                        </h5>
                        <p class="card-text text-muted small line-clamp-3">
                            <%= item.summary %>
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 p-4 pt-0">
                        <a href="/news/<%= item._id %>" class="text-primary fw-bold text-decoration-none small">
                            Đọc tiếp <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<style>
    .hover-card:hover { transform: translateY(-5px); transition: 0.3s; }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<%- include('partials/footer') %>