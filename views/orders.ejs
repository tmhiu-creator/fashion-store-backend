<%- include('partials/header.ejs') %>

<div class="container py-5 mb-5">
    <h2 class="fw-bold mb-4 font-heading border-bottom pb-3">Đơn Hàng Của Tôi</h2>

    <div class="row">
        <div class="col-12">
            <% if (orders.length === 0) { %>
                <div class="text-center py-5 bg-light rounded-3">
                    <i class="bi bi-inbox fs-1 text-muted"></i>
                    <p class="mt-3 text-muted">Bạn chưa có đơn hàng nào.</p>
                    <a href="/" class="btn btn-dark rounded-pill">Mua sắm ngay</a>
                </div>
            <% } else { %>
                
                <% orders.forEach(order => { %>
                    <div class="card border-0 shadow-sm mb-4 overflow-hidden">
                        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold text-uppercase me-2">Mã đơn: #<%= order._id.toString().slice(-6).toUpperCase() %></span>
                                <span class="text-muted small">| <%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></span>
                            </div>
                            <div>
                                <% if(order.status === 'Chờ xác nhận') { %>
                                    <span class="badge bg-warning text-dark"><%= order.status %></span>
                                <% } else if (order.status === 'Hoàn thành') { %>
                                    <span class="badge bg-success"><%= order.status %></span>
                                <% } else { %>
                                    <span class="badge bg-secondary"><%= order.status %></span>
                                <% } %>
                            </div>
                        </div>
                        <div class="card-body">
                            <% order.items.forEach(item => { %>
                                <div class="d-flex align-items-center mb-3 border-bottom pb-3 last-no-border">
                                    <img src="<%= item.image %>" class="rounded me-3" style="width: 70px; height: 70px; object-fit: cover;">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 fw-bold"><%= item.name %></h6>
                                        <p class="mb-0 small text-muted">
                                            Phân loại: <%= item.color %>, Size <%= item.size %>
                                            <br>
                                            x<%= item.qty %>
                                        </p>
                                    </div>
                                    <div class="text-end">
                                        <span class="text-primary fw-bold"><%= (item.price * item.qty).toLocaleString('vi-VN') %> đ</span>
                                    </div>
                                </div>
                            <% }) %>
                            
                            <div class="d-flex justify-content-end align-items-center mt-3 pt-3 border-top">
                                <span class="me-3 text-muted">Tổng số tiền:</span>
                                <h4 class="fw-bold text-danger m-0"><%= order.totalMoney.toLocaleString('vi-VN') %> đ</h4>
                            </div>
                        </div>
                    </div>
                <% }) %>

            <% } %>
        </div>
    </div>
</div>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('status') === 'success') {
        // Xóa giỏ hàng trong LocalStorage theo User
        const userId = "<%= user._id %>";
        const cartKey = `cart_${userId}`;
        localStorage.removeItem(cartKey);
        
        // Cập nhật lại header về 0
        const headerBadge = document.getElementById('header-cart-count');
        if(headerBadge) headerBadge.classList.add('d-none');
        
        // Xóa query param trên URL cho đẹp
        window.history.replaceState({}, document.title, "/my-orders");
        
        alert("✅ Đặt hàng thành công! Cảm ơn bạn đã mua sắm.");
    }
</script>

<style>
    .last-no-border:last-child { border-bottom: none !important; padding-bottom: 0 !important; }
</style>

<%- include('partials/footer.ejs') %>