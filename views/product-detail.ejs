<%- include('partials/header.ejs') %>

<div class="bg-light py-5">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-4">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Sản phẩm</a></li>
                <li class="breadcrumb-item active text-dark fw-bold" aria-current="page"><%= product.name %></li>
            </ol>
        </nav>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <div class="row g-0">
                    <div class="col-lg-6 bg-white p-4 d-flex align-items-center justify-content-center border-end">
                        <div class="position-relative w-100 text-center">
                            <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-3 py-2 text-uppercase fw-bold shadow-sm">Hot</span>
                            <img src="<%= product.image %>" class="img-fluid rounded-3 product-main-img" 
                                 alt="<%= product.name %>" style="max-height: 500px; object-fit: contain;"
                                 onerror="this.src='https://placehold.co/500x500?text=No+Image'">
                        </div>
                    </div>

                    <div class="col-lg-6 p-5">
                        <h2 class="fw-bold text-dark mb-2"><%= product.name %></h2>
                        
                        <div class="d-flex align-items-center mb-4">
                            <div class="text-warning small me-2">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                            </div>
                            <span class="text-muted small">(50 đánh giá)</span>
                        </div>

                        <h3 class="text-primary fw-bold mb-4 price-tag"><%= product.price.toLocaleString('vi-VN') %> đ</h3>

                        <p class="text-muted mb-4 line-clamp-3">
                            <%= product.description || 'Chất liệu cao cấp, thoáng mát. Thiết kế trẻ trung, phù hợp đi làm, đi chơi...' %>
                        </p>

                        <div class="mb-4">
                            <label class="fw-bold mb-2 d-block small text-uppercase">Chọn Size:</label>
                            <div class="d-flex gap-2">
                                <% ['S', 'M', 'L', 'XL'].forEach((s, index) => { %>
                                    <input type="radio" class="btn-check" name="size" id="size-<%= s %>" value="<%= s %>" <%= index===1 ? 'checked' : '' %>>
                                    <label class="btn btn-outline-dark rounded-pill px-4" for="size-<%= s %>"><%= s %></label>
                                <% }); %>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold mb-2 d-block small text-uppercase">Chọn Màu:</label>
                            <div class="d-flex gap-2">
                                <% ['Trắng', 'Đen', 'Xanh'].forEach((c, index) => { %>
                                    <input type="radio" class="btn-check" name="color" id="color-<%= index %>" value="<%= c %>" <%= index===0 ? 'checked' : '' %>>
                                    <label class="btn btn-outline-secondary rounded-pill px-3" for="color-<%= index %>"><%= c %></label>
                                <% }); %>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex align-items-center gap-3">
                            <div class="input-group rounded-pill border overflow-hidden" style="width: 140px;">
                                <button class="btn btn-light border-0 px-3" type="button" onclick="decreaseQty()">-</button>
                                <input type="text" class="form-control text-center border-0 bg-white fw-bold" id="qty" value="1" readonly>
                                <button class="btn btn-light border-0 px-3" type="button" onclick="increaseQty()">+</button>
                            </div>

                            <button class="btn btn-dark flex-grow-1 py-3 rounded-pill fw-bold text-uppercase shadow-sm hover-top transition-btn"
                                type="button"
                                data-id="<%= product._id %>"
                                data-name="<%= product.name %>"
                                data-price="<%= product.price %>"
                                data-image="<%= product.image %>"
                                onclick="addToCartDetail(this)">
                                <i class="bi bi-bag-plus me-2"></i> Thêm vào giỏ hàng
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/product-detail.js"></script>
<%- include('partials/footer.ejs') %>